<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login – Globe Weather</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="min-height:100vh;margin:0;background:linear-gradient(135deg,#1a0033,#2a0a4a,#003366);display:flex;align-items:center;justify-content:center;color:white;font-family:system-ui,sans-serif;">

  <div style="background:rgba(30,30,60,0.75);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.15);border-radius:1rem;padding:2.5rem;width:100%;max-width:420px;box-shadow:0 15px 40px rgba(0,0,0,0.6);">
    <h1 style="font-family:'Titan One',cursive;font-size:3.8rem;color:#ffdd99;text-shadow:0 0 30px rgba(255,210,120,0.7);margin-bottom:2rem;text-align:center;">Globe</h1>

    <% if (error) { %>
      <div style="color:#ff9999;margin-bottom:1.2rem;text-align:center;font-weight:500;"><%= error %></div>
    <% } %>

    <form method="POST">
      <div class="mb-3">
        <input type="text" class="form-control form-control-lg" name="username" placeholder="Username" required autofocus>
      </div>
      <div class="mb-4">
        <input type="password" class="form-control form-control-lg" name="password" placeholder="Password" required>
      </div>
      <button type="submit" style="background:linear-gradient(90deg,#ffaa4e,#ffdd99);border:none;font-weight:bold;color:#1a1a2e;" class="btn btn-lg w-100">Sign In</button>
    </form>
  </div>

</body>
</html>