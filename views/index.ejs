<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Globe Weather</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Titan+One&family=Gloria+Hallelujah&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>

  <h1 class="app-title">Globe Weather</h1>

  <div id="weatherCarousel" class="carousel slide" data-bs-ride="true" data-bs-interval="6500">

    <div class="carousel-indicators">
      <% citiesData.forEach((_, i) => { %>
        <button type="button" data-bs-target="#weatherCarousel" data-bs-slide-to="<%= i %>"
                class="<%= i === 0 ? 'active' : '' %>" aria-current="<%= i === 0 %>"
                aria-label="Slide <%= i+1 %>"></button>
      <% }) %>
    </div>

    <div class="carousel-inner">
      <% citiesData.forEach((city, i) => { %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <% if (city.image) { %>
            <div class="weather-bg" style="background-image: url('<%= city.image %>');"></div>
          <% } %>
          <div class="overlay">
            <h2 class="city-title"><%= city.cityName %></h2>
            <p class="country"><%= city.countryName %></p>

            <div class="info-row">
              <span class="emoji">🌡️</span> <%= city.temperature %> °C
            </div>
            <div class="info-row">
              <span class="emoji">💧</span> Humidity: <%= city.humidity %>%
            </div>
            <div class="info-row">
              <span class="emoji">💨</span> Wind: <%= city.windspeed %> m/s
            </div>
            <div class="info-row">
              <span class="emoji">☁️</span> <%= city.sky_condition.charAt(0).toUpperCase() + city.sky_condition.slice(1) %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#weatherCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#weatherCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>